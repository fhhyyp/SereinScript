// 快速排序
let swap = (arr, i, j) => {
    let tmp = arr[i]
    arr[i] = arr[j]
    arr[j] = tmp
}

let partition = (arr, low, high) => {
    let pivot = arr[high]
    var i = low - 1

    var j = low
    for j in range(low, high) {
        if arr[j] <= pivot then {
            i = i + 1
            swap(arr, i, j)
        }
    }

    swap(arr, i + 1, high)
    return i + 1
}

let quickSort = (arr, low, high) => {
    if low < high then {
        let pi = partition(arr, low, high)
        quickSort(arr, low, pi - 1)
        quickSort(arr, pi + 1, high)
    }
}

