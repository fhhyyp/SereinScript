let arrayFunc = (arr) => {
	let value = arr
	var arrayObject = {
		count = value.length,
		select = (fn) => {
			var result = []
			for item in value {
				result = result + fn(item)
			}
			return arrayFunc(result) 
		},
		toArray = () => value
	}
	return arrayObject
}

return {
	array = arrayFunc,
}