import { array:linq } from "linq.script"

let arr = [1, 2, 3, 4, 213, 451, 2, 542, 534, 12, 3, 34, 51, 23, 412, 
			32, 54, 1, 32, 245, 23,412,512,321,521,321312,23,213,213,21,4521,
			34,21,321,3,21,4521,4,21,5,43,543,67,547,254,7,24,76542,6,426,5426,
			542654,6542,65426,542654,2624,62,435624,435]

let result = linq(arr).where(x => x % 2 == 0)
					  .select(x => x / 10)
					  .toList()

print("输出:" ,result)

