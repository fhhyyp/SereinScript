// test-stack-overflow.script
print("=== 栈深度测试 ===")

let deepRecursion = (n, max) => {
    if n >= max then {
        print("到达深度: " + n)
        n
    } else {
        deepRecursion(n + 1, max)
    }
}

// 测试不同深度
let testDepth = (depth) => {
    print("测试深度: " + depth)
    let result = deepRecursion(0, depth)
    print("结果: " + result)
}

testDepth(232)
testDepth(500)
testDepth(1000)
testDepth(5000)
testDepth(10000)
testDepth(50000)
testDepth(100000)
testDepth(500000)
testDepth(1000000)
testDepth(5000000)
testDepth(10000000)