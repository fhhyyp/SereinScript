// look.script
import { store } from "data.script"

let look = () => { 
	print("current state :")       
	print("x    : ", store.state.x)       
	print("y    : ", store.state.y)     
	print("data : ", store.getters.getData()) 
	print("---------------------------------------------------")       
}

return { 
	look = look
}

