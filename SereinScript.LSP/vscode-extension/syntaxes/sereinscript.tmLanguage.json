{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SereinScript",
  "scopeName": "source.sereinscript",
  "fileTypes": ["script"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sereinscript",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sereinscript",
          "match": "\\b(let|var|if|then|else|when|for|in|return|import|from)\\b"
        },
        {
          "name": "constant.language.sereinscript",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sereinscript",
          "begin": "\"",
          "end": "\"",
          "escapes": [
            {
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.sereinscript",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.sereinscript",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*=\\s*\\([^)]*\\)\\s*=>"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.sereinscript",
          "match": "(\\+|\\-|\\*|\\/|\\%|\\=|\\==|\\!=|\\<|\\<=|\\>|\\>=|\\!|\\&&|\\|||=>)"
        }
      ]
    }
  }
}