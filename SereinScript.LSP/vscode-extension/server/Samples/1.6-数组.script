
// ==================== 数组 ====================
let arr = [1, 2, 3, 4, 5]
print("arr:", arr)  // 输出: arr: [1, 2, 3, 4, 5]
print("arr[0]:", arr[0])  // 输出: arr[0]: 1
print("arr.length:", arr.length)  // 输出: arr.length: 5

// 数组拼接
let arr2 = arr + [6, 7, 8]
print("arr2:", arr2)  // 输出: arr2: [1, 2, 3, 4, 5, 6, 7, 8]

arr2